    const rateRow=div();const spreadRow=div();
    const cpiNote=infoAlert('rgba(16,185,129,.08)','rgba(16,185,129,.2)','#10b981','<p style="margin:0;font-size:12px;color:#10b981">📊 הלוואה צמודת מדד — עדכן מדד חודשי לאחר שמירה</p>');
    const prevBox=div(null,{style:{background:'rgba(99,102,241,.1)',border:'1px solid rgba(99,102,241,.2)',borderRadius:'14px',padding:'14px',marginTop:'14px',textAlign:'center',display:'none'}});

    function updatePreview(){
      const P=parseFloat(pInp.value)||0,n=parseInt(tInp.value)||0;
