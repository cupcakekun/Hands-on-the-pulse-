function buildCard(loan,ci){
  const color=COLORS[ci%COLORS.length];
  const s=stats(loan,S.cpi);
  const progress=Math.min(100,((s.idx+1)/(parseInt(loan.termMonths)||1))*100);
  const isPrime=loan.loanType==='פריים';
  const isBalloon=loan.loanType==='בלון';
  const P=parseFloat(loan.principal)||1;

  const card=div('card',{style:{border:'1px solid '+color+'33'}});
  // FIX: שמור ID על הכרטיס לצורך refreshCard
  card.dataset.loanId=loan.id;

  // ── Header ──
  const hdr=div(null,{style:{padding:'18px 18px 0',borderBottom:'1px solid var(--border)'}});

  const topRow=div('row-between mb8');
  const titleBlock=div();
  const tagsRow=div('row mb8',{style:{flexWrap:'wrap',gap:'6px'}});
  add(tagsRow,tag(color,loan.loanType||'שפיצר'));
  if(isPrime){const cp=primeAt(loan.primeHistory||[],nowYM());add(tagsRow,tag('#f59e0b','פריים '+cp+'%'));}
  add(titleBlock,tagsRow,
    mk('h3',null,loan.name,{style:{fontSize:'20px',fontWeight:'900',margin:'0 0 3px',color:'var(--text)'}}),
    mk('p',null,(isPrime?'מרווח '+loan.annualRate+'%':loan.annualRate+'% שנתי')+' · '+loan.termMonths+' ח׳ · '+loan.startDate.slice(0,7),
      {style:{fontSize:'12px',color:'var(--text4)',margin:'0'}}));

  const acts=div('row',{style:{gap:'6px',flexShrink:'0'}});
  if(isPrime){
    const pb=el('button','btn-icon');pb.textContent='📈';pb.title='עדכן פריים';
    pb.style.background='rgba(245,158,11,.12)';pb.style.color='#f59e0b';
    pb.addEventListener('click',()=>openPrimeSheet(loan));add(acts,pb);
  }
  const eb=el('button','btn-icon');eb.textContent='✏️';eb.style.color='var(--text2)';eb.addEventListener('click',()=>openLoanSheet(loan));add(acts,eb);
  const db=el('button','btn-icon');db.textContent='✕';db.style.color='var(--red)';db.style.background='rgba(239,68,68,.1)';
  db.addEventListener('click',()=>{if(confirm('למחוק את "'+loan.name+'"?'))setLoans(S.loans.filter(l=>l.id!==loan.id));});
  add(acts,db);
  add(topRow,titleBlock,acts);add(hdr,topRow);

  // Balance
  const balDiv=div(null,{style:{textAlign:'center',padding:'14px 0 18px'}});
  add(balDiv,
    mk('p',null,'יתרת חוב עכשיו',{style:{margin:'0 0 2px',fontSize:'11px',color:'var(--text4)',fontWeight:'700',letterSpacing:'2px',textTransform:'uppercase'}}),
    mk('p',null,ils(s.balance),{style:{margin:'0',fontSize:'42px',fontWeight:'900',letterSpacing:'-2px',lineHeight:'1',color:s.balance>P*.5?'var(--red)':'var(--green)'}}));
  const subLine=div('row',{style:{justifyContent:'center',gap:'12px',marginTop:'6px',fontSize:'12px',color:'var(--text4)',flexWrap:'wrap'}});
  const pmtSpan=mk('span',null,ils2(s.curPmt));pmtSpan.style.color=color;pmtSpan.style.fontWeight='700';
  const remSpan=mk('span',null,s.monthsLeft+' חודשים');remSpan.style.color='var(--yellow)';remSpan.style.fontWeight='700';
  add(subLine,mk('span',null,'תשלום: '),pmtSpan,mk('span',null,'·'),mk('span',null,'נותרו: '),remSpan);
  add(balDiv,subLine);add(hdr,balDiv);

  // Progress
  const progWrap=div('mb16');
  const progLbl=div('row-between smaller dim2 mb8');
  add(progLbl,mk('span',null,'חודש '+(s.idx+1)+' / '+loan.termMonths),mk('span',null,progress.toFixed(0)+'% הסתיים'));
  const track=div('prog-track');const fill=div('prog-fill');
  fill.style.width=progress+'%';fill.style.background='linear-gradient(90deg,'+color+','+color+'88)';
  add(track,fill);add(progWrap,progLbl,track);add(hdr,progWrap);

  // Tabs
