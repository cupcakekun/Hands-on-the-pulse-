    tabEls[id]=t;add(tabsRow,t);
  });
  add(hdr,tabsRow);add(card,hdr);

  // ── Panels ──
  const panelWrap=div(null,{style:{padding:'18px'}});

  // INFO
  const infoP=div(null,{style:{display:savedTab==='info'?'block':'none'}});
