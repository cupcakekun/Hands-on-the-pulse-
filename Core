<body>
<div id="app"></div>
<script>
'use strict';
// ═══════════════════════════════════════════════════════════
//  CONSTANTS & STORAGE
// ═══════════════════════════════════════════════════════════
const K={loans:'yadv4_loans',cpi:'yadv4_cpi'};
const COLORS=['#3b82f6','#f59e0b','#10b981','#ef4444','#8b5cf6','#ec4899','#06b6d4','#14b8a6'];
const MONTHS=['ינו׳','פבר׳','מרץ','אפר׳','מאי','יוני','יולי','אוג׳','ספט׳','אוק׳','נוב׳','דצמ׳'];
const TYPES=['שפיצר','פריים','בלון','צמוד מדד','משכנתה מעורבת'];

const LS={
  get:(k,d)=>{try{const v=localStorage.getItem(k);return v!==null?JSON.parse(v):d;}catch{return d;}},
  set:(k,v)=>{try{localStorage.setItem(k,JSON.stringify(v));}catch{}}
};

// ═══════════════════════════════════════════════════════════
//  FORMATTERS
// ═══════════════════════════════════════════════════════════
const ils  = n=>new Intl.NumberFormat('he-IL',{style:'currency',currency:'ILS',maximumFractionDigits:0}).format(n||0);
const ils2 = n=>new Intl.NumberFormat('he-IL',{style:'currency',currency:'ILS',maximumFractionDigits:2}).format(n||0);
const fmtMY= d=>d?new Date(d).toLocaleDateString('he-IL',{month:'2-digit',year:'numeric'}):'—';
const ym   = (y,m)=>y+'-'+String(m).padStart(2,'0');
const nowYM= ()=>{const n=new Date();return ym(n.getFullYear(),n.getMonth()+1);};

// ═══════════════════════════════════════════════════════════
//  MATH ENGINE
// ═══════════════════════════════════════════════════════════
function parseDate(s){
  const p=(s||'').split('-').map(Number);
  return(!p[0]||!p[1]||isNaN(p[0])||isNaN(p[1]))?null:{y:p[0],m:p[1]};
}
function pmt(P,rate,n){
  const r=rate/100/12;
  if(r===0)return P/n;
  return P*(r*Math.pow(1+r,n))/(Math.pow(1+r,n)-1);
}
function primeAt(hist,ymStr){
  if(!hist||!hist.length)return 0;
  const s=[...hist].sort((a,b)=>a.date.localeCompare(b.date));
  let r=s[0].rate;
  for(const h of s){if(h.date<=ymStr)r=h.rate;else break;}
  return r;
}
function cpiAt(hist,ymStr){
  if(!hist||!hist.length)return 1;
  const s=[...hist].sort((a,b)=>a.date.localeCompare(b.date));
  let v=s[0].index;
  for(const h of s){if(h.date<=ymStr)v=h.index;else break;}
  return v;
}
function buildSchedule(loan,cpiHist){
  const pd=parseDate(loan.startDate);
  if(!pd)return[];
  const P=parseFloat(loan.principal)||0,n=parseInt(loan.termMonths)||0;
  if(!n||!P)return[];
  const rate=parseFloat(loan.annualRate)||0,spread=parseFloat(loan.spread)||0;
  let bal=P;const rows=[];
  for(let i=0;i<n;i++){
    const d=new Date(pd.y,pd.m-1+i);
    const ymNow=ym(d.getFullYear(),d.getMonth()+1);
    let payment,interest,principal;
    if(loan.loanType==='פריים'){
      const r=(primeAt(loan.primeHistory||[],ymNow)+spread)/100/12;
      const rem=n-i;
      const p2=rem<=0?bal:(r===0?bal/rem:bal*(r*Math.pow(1+r,rem))/(Math.pow(1+r,rem)-1));
      interest=bal*r;principal=Math.min(Math.max(0,p2-interest),bal);payment=p2;
    }else if(loan.loanType==='בלון'){
      const r=rate/100/12;
      interest=bal*r;principal=i===n-1?bal:0;payment=interest+principal;
    }else if(loan.loanType==='צמוד מדד'){
      if(i>0){
        const prevD=new Date(pd.y,pd.m-1+i-1);
        const prevYM=ym(prevD.getFullYear(),prevD.getMonth()+1);
        const cp=cpiAt(cpiHist||[],prevYM),cn=cpiAt(cpiHist||[],ymNow);
        if(cp>0)bal=bal*(cn/cp);
      }
      const r=rate/100/12,rem=n-i;
      const p2=rem<=0?bal:(r===0?bal/rem:bal*(r*Math.pow(1+r,rem))/(Math.pow(1+r,rem)-1));
      interest=bal*r;principal=Math.min(Math.max(0,p2-interest),bal);payment=p2;
    }else{
      const r=rate/100/12,p2=pmt(P,rate,n);
      interest=bal*r;principal=Math.min(Math.max(0,p2-interest),bal);payment=p2;
    }
    bal=Math.max(0,bal-principal);
    rows.push({month:i+1,label:MONTHS[d.getMonth()]+' '+d.getFullYear(),
      ymStr:ymNow,date:new Date(d),interest,principal,payment,balance:bal});
  }
  return rows;
}
function curIdx(loan){
  const pd=parseDate(loan.startDate);
  if(!pd)return 0;
  const now=new Date(),n=parseInt(loan.termMonths)||1;
  return Math.max(0,Math.min((now.getFullYear()-pd.y)*12+(now.getMonth()-(pd.m-1)),n-1));
}

// FIX: חישוב פיגורים לפי ימים + ימי חסד (כמו בנקים)
function calcArrears(loan,cpi){
  const missed=loan.missedMonths||[];
  const penaltyRate=parseFloat(loan.penaltyRate)||0;
  const graceDays=parseInt(loan.graceDays!=null?loan.graceDays:14,10);
  const sched=buildSchedule(loan,cpi);
  if(!missed.length)return{total:0,penalty:0,principal:0,missedCount:0};
  const now=new Date();
  let totalMissed=0,totalPenalty=0;
  missed.forEach(m=>{
    const row=sched.find(r=>r.ymStr===m.ymStr);
    if(!row)return;
    totalMissed+=row.payment;
    if(penaltyRate>0){
      const missedDate=new Date(row.date);
      missedDate.setDate(missedDate.getDate()+graceDays);
      const daysOverdue=Math.max(0,Math.floor((now-missedDate)/86400000));
      const dailyRate=penaltyRate/100/365;
      totalPenalty+=row.payment*dailyRate*daysOverdue;
    }
  });
  return{total:totalMissed+totalPenalty,penalty:totalPenalty,principal:totalMissed,missedCount:missed.length};
}

function stats(loan,cpi){
  const sched=buildSchedule(loan,cpi);
  const idx=curIdx(loan);
  const si=sched.length?Math.max(0,Math.min(idx,sched.length-1)):0;
  const extra=(loan.payments||[]).reduce((s,p)=>s+p.amount,0);
  const row=sched[si];
  const arrears=calcArrears(loan,cpi);
  const balance=Math.max(0,(row?row.balance:0)-extra+arrears.total);
  const totalInt=sched.reduce((s,r)=>s+r.interest,0);
  const paidInt=sched.slice(0,si+1).reduce((s,r)=>s+r.interest,0);
  const endDate=sched.length?sched[sched.length-1].date:null;
  const curPmt=row?row.payment:0;
  const monthsLeft=Math.max(0,(parseInt(loan.termMonths)||0)-si-1);
  return{sched,idx:si,extra,balance,totalInt,paidInt,endDate,curPmt,monthsLeft,arrears};
}

function earlyCalc(loan,extra,cpi){
  const s=stats(loan,cpi);
  if(s.balance<=0||extra<=0)return null;
  const r=parseFloat(loan.annualRate)/100/12;
  let bal=s.balance,origInt=0;
  for(let i=0;i<s.monthsLeft;i++){const int=bal*r;origInt+=int;bal=Math.max(0,bal-(s.curPmt-int));}
  bal=s.balance;let newInt=0,newM=0;
  while(bal>0.01&&newM<600){const int=bal*r;newInt+=int;bal=Math.max(0,bal-(s.curPmt+extra-int));newM++;}
  const ned=new Date();ned.setDate(1);ned.setMonth(ned.getMonth()+newM);
  return{saved:Math.max(0,origInt-newInt),savedM:Math.max(0,s.monthsLeft-newM),newEnd:ned};
}

// ═══════════════════════════════════════════════════════════
//  DOM HELPERS
// ═══════════════════════════════════════════════════════════
function el(tag,cls,attrs){
  const e=document.createElement(tag);
  if(cls)e.className=cls;
  if(attrs)for(const[k,v]of Object.entries(attrs)){
    if(k==='style'&&typeof v==='object')Object.assign(e.style,v);
    else if(k.startsWith('on'))e.addEventListener(k.slice(2).toLowerCase(),v);
    else e.setAttribute(k,v);
  }
  return e;
}
function mk(tag,cls,txt,attrs){const e=el(tag,cls,attrs);if(txt!==undefined&&txt!==null)e.textContent=txt;return e;}
function div(cls,attrs){return el('div',cls,attrs);}
function add(parent,...children){children.flat().forEach(c=>{if(c!=null)parent.appendChild(typeof c==='string'?document.createTextNode(c):c);});return parent;}

function tag(color,text){
  const s=el('span','tag');s.textContent=text;
  s.style.background=color+'22';s.style.color=color;return s;
}
function statBox(lbl,val,sub,color){
  const d=div('stat-box');
  add(d,mk('p',null,lbl,{style:{margin:'0 0 4px',fontSize:'10px',color:'var(--text4)',fontWeight:'700',textTransform:'uppercase'}}));
  add(d,mk('p',null,val,{style:{margin:'0',fontSize:'18px',fontWeight:'800',color:color||'var(--text)'}}));
  if(sub)add(d,mk('p',null,sub,{style:{margin:'2px 0 0',fontSize:'11px',color:'var(--text3)'}}));
  return d;
}
function inputField(cls,attrs){return el('input',cls?'inp '+cls:'inp',attrs);}
function selectField(options,val){
  const s=el('select','inp');
  options.forEach(o=>{const op=el('option');op.value=op.textContent=o;if(o===val)op.selected=true;s.appendChild(op);});
  return s;
}
function btn(cls,text,handler){const b=mk('button',cls,text);if(handler)b.addEventListener('click',handler);return b;}
function lbl(text){return mk('label','field-lbl',text);}

function infoAlert(bg,border,color,html){
  const d=div(null,{style:{background:bg,border:'1px solid '+border,borderRadius:'14px',padding:'12px 14px',marginBottom:'12px'}});
  d.innerHTML=html;return d;
}

// ═══════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════
const S={
  loans:LS.get(K.loans,[]),
  cpi:  LS.get(K.cpi,[]),
  view: 'loans',
  // FIX: שמור את הטאב הפעיל לפי מזהה הלוואה — לא נאבד מיקום אחרי render
  activeTab:{},
};
function save(){LS.set(K.loans,S.loans);LS.set(K.cpi,S.cpi);}

// FIX: setLoans עם updateOnly — רק מעדכן נתונים, לא מבנה DOM
function setLoans(l,loanIdToRefresh){
  S.loans=l;save();
  if(loanIdToRefresh){
    refreshCard(loanIdToRefresh);
    // עדכן גם את ה-header summary בלבד
    renderSummary();
  }else{
    render();
  }
}

