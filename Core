    statBox('סה"כ ריבית',ils(s.totalInt),(s.totalInt/P*100).toFixed(1)+'% מהקרן','var(--orange)'),
    statBox('ריבית ששולמה',ils(s.paidInt),'','var(--yellow)'),
    statBox('תאריך סיום',fmtMY(s.endDate),'','var(--blue)'));
  add(infoP,sg);
  if(isBalloon)add(infoP,infoAlert('rgba(239,68,68,.08)','rgba(239,68,68,.2)','','<p style="margin:0;font-size:12px;color:var(--red)">⚠️ הלוואת בלון — הקרן ('+ils(P)+') תשולם בתשלום אחד בסוף התקופה</p>'));
  if(s.extra>0)add(infoP,infoAlert('rgba(74,222,128,.08)','rgba(74,222,128,.2)','','<p style="margin:0;font-size:13px;color:var(--green)">✓ תשלומים נוספים: <strong>'+ils2(s.extra)+'</strong></p>'));
  const payRow=div('row');
  const payInp=inputField(null,{type:'number',placeholder:'רשום תשלום (₪)'});payInp.style.flex='1';
  const payBtn=btn(null,'+ שולם',()=>{
    const v=parseFloat(payInp.value);if(!isNaN(v)&&v>0){
      const updated=S.loans.map(l=>l.id===loan.id?{...l,payments:[...(l.payments||[]),{amount:v,date:new Date().toISOString().slice(0,10)}]}:l);
      setLoans(updated,loan.id);
      payInp.value='';
    }
  });
  payBtn.style.cssText='background:linear-gradient(135deg,'+color+','+color+'88);border:none;color:#fff;border-radius:12px;padding:0 18px;cursor:pointer;font-weight:800;font-size:15px;height:48px;white-space:nowrap';
  payInp.addEventListener('keydown',e=>{if(e.key==='Enter')payBtn.click();});
  add(payRow,payInp,payBtn);add(infoP,payRow);
  panels['info']=infoP;

  // SCHEDULE — toggle switches + accordion לפי שנה
  const schedP=div(null,{style:{display:savedTab==='sched'?'block':'none'}});
  // שמור מצב תצוגה (רשימה / שנה) ואיזה שנים פתוחות
  const schedState={view: S.schedView&&S.schedView[loan.id] ? S.schedView[loan.id] : 'year', openYears:{}};

  function doToggleMissed(ymStr,payment){
    const freshLoan=S.loans.find(l=>l.id===loan.id);
    if(!freshLoan)return;
    const freshMissed=new Set((freshLoan.missedMonths||[]).map(m=>m.ymStr));
    let mm=[...(freshLoan.missedMonths||[])];
    if(freshMissed.has(ymStr)){mm=mm.filter(m=>m.ymStr!==ymStr);}
    else{mm.push({ymStr,payment});}
    if(navigator.vibrate)navigator.vibrate(20);
    const updated=S.loans.map(l=>l.id===loan.id?{...l,missedMonths:mm}:l);
    setLoans(updated,loan.id);
  }

  function buildMonthRow(row,i,curIdx2,curMissed){
    const isCur=i===curIdx2,isPast=i<curIdx2,isFuture=!isPast&&!isCur;
    const isMissed=curMissed.has(row.ymStr);
    const canToggle=isPast||isCur;

    const wrap=div('toggle-wrap'+(isMissed?' is-missed':isFuture?' is-future':isCur?' is-cur':''));
    if(isCur){wrap.style.setProperty('--cur-color',color+'18');wrap.style.setProperty('--cur-border',color+'44');}

    // שמאל: שם חודש + תאריך + תשלום
    const left=div(null,{style:{flex:'1',minWidth:0}});
    const topLine=div('row',{style:{gap:'6px',marginBottom:'3px'}});
    const monthLbl=mk('span',null,(isCur?'▶ ':'')+row.label,{style:{
      fontSize:'13px',fontWeight:isCur||isMissed?'800':'600',
      color:isMissed?'var(--red)':isCur?color:'var(--text)'}});
    add(topLine,monthLbl);
    if(isMissed)add(topLine,mk('span',null,'מפוגר',{style:{fontSize:'10px',fontWeight:'700',color:'var(--red)',background:'rgba(248,113,113,.15)',padding:'1px 6px',borderRadius:'6px'}}));
    add(left,topLine);
    const botLine=div('row',{style:{gap:'10px',fontSize:'11px',color:'var(--text4)'}});
    add(botLine,
      mk('span',null,'תשלום: ',null),
      mk('span',null,ils(row.payment),{style:{color:isMissed?'var(--red)':'var(--blue)',fontWeight:'700'}}),
      mk('span',null,'·'),
      mk('span',null,'יתרה: '),
      mk('span',null,ils(row.balance),{style:{color:'var(--text2)'}}));
    add(left,botLine);
    add(wrap,left);

    // ימין: toggle switch
    const sw=div('sw'+(isMissed?' missed':canToggle&&!isMissed?' on':''));
    if(isFuture)sw.style.opacity='0.3';
    add(wrap,sw);

    if(canToggle){
      wrap.addEventListener('click',()=>doToggleMissed(row.ymStr,row.payment));
    }
    return wrap;
  }

  function rebuildSchedContent(currentLoan){
    schedP.innerHTML='';
    const curMissed=new Set((currentLoan.missedMonths||[]).map(m=>m.ymStr));
    const curArrears=calcArrears(currentLoan,S.cpi);
    const curSched=buildSchedule(currentLoan,S.cpi);
    const curIdx2=curIdx(currentLoan);

    // תיבת פיגורים
    if(curMissed.size>0){
      const ab=div('arrears-box');
      add(ab,mk('p',null,'⚠️ פיגור תשלומים',{style:{fontSize:'14px',fontWeight:'800',color:'var(--red)',margin:'0 0 12px'}}));
      const ag=div('g2',{style:{marginBottom:'10px'}});
      add(ag,
        statBox('חודשים מפוגרים',curMissed.size+' חודשים','','var(--red)'),
        statBox('קרן מפוגרת',ils(curArrears.principal),'','var(--red)'));
      add(ab,ag);
      if(curArrears.penalty>0){
        add(ab,div(null,{style:{marginBottom:'8px'}}));
        add(ab,statBox('ריבית פיגורים שנצברה',ils(curArrears.penalty),'','var(--orange)'));
      }
      add(ab,div(null,{style:{marginBottom:'8px'}}));
      add(ab,statBox('סה"כ חוב פיגורים',ils(curArrears.total),'קרן + ריבית פיגורים','var(--red)'));
      add(schedP,ab);
    }

    // כפתורי תצוגה
    const viewBtns=div('sched-view-btns');
    const btnList=btn('sched-view-btn'+(schedState.view==='list'?' on':''),'📋 רשימה',()=>{
      schedState.view='list';
      if(!S.schedView)S.schedView={};
      S.schedView[loan.id]='list';
      rebuildSchedContent(S.loans.find(l=>l.id===loan.id)||currentLoan);
    });
    const btnYear=btn('sched-view-btn'+(schedState.view==='year'?' on':''),'📅 לפי שנה',()=>{
      schedState.view='year';
      if(!S.schedView)S.schedView={};
      S.schedView[loan.id]='year';
      rebuildSchedContent(S.loans.find(l=>l.id===loan.id)||currentLoan);
    });
    add(viewBtns,btnYear,btnList);
    add(schedP,viewBtns);

    add(schedP,mk('p',null,'לחץ על שורה לסימון כמפוגר / שולם',{style:{fontSize:'11px',color:'var(--text4)',marginBottom:'10px'}}));

    if(schedState.view==='list'){
      // תצוגת רשימה רגילה עם scroll
      const listWrap=div(null,{style:{maxHeight:'380px',overflowY:'auto'}});
      curSched.forEach((row,i)=>add(listWrap,buildMonthRow(row,i,curIdx2,curMissed)));
      add(schedP,listWrap);
    } else {
      // תצוגת accordion לפי שנה
      const byYear={};
      curSched.forEach((row,i)=>{
        const y=row.date.getFullYear();
        if(!byYear[y])byYear[y]=[];
        byYear[y].push({row,i});
      });
      // פתח את השנה הנוכחית אוטומטית
      const nowYear=new Date().getFullYear();
      if(schedState.openYears[nowYear]===undefined)schedState.openYears[nowYear]=true;

      Object.keys(byYear).forEach(year=>{
        const entries=byYear[year];
        const isOpen=!!schedState.openYears[year];
        const missedInYear=entries.filter(({row})=>curMissed.has(row.ymStr)).length;
        const paidInYear=entries.filter(({row,i})=>!curMissed.has(row.ymStr)&&i<=curIdx2).length;
        const totalInYear=entries.length;

        const yrSec=div(null,{style:{marginBottom:'6px'}});
        const yrHdr=div('yr-hdr');

        const yrLeft=div('row',{style:{gap:'8px'}});
        add(yrLeft,mk('span',null,'שנת '+year,{style:{fontSize:'14px'}}));
        if(missedInYear>0){
          const badge=mk('span','yr-badge',missedInYear+' מפוגרים');
          badge.style.background='rgba(248,113,113,.15)';badge.style.color='var(--red)';
          add(yrLeft,badge);
        }
        add(yrLeft,mk('span',null,paidInYear+'/'+totalInYear,{style:{fontSize:'11px',color:'var(--text4)'}}));

        const arrow=mk('span',null,isOpen?'▲':'▼',{style:{fontSize:'12px',color:'var(--text4)'}});
        add(yrHdr,yrLeft,arrow);

        const yrBody=div(null,{style:{display:isOpen?'block':'none'}});
        entries.forEach(({row,i})=>add(yrBody,buildMonthRow(row,i,curIdx2,curMissed)));

        yrHdr.addEventListener('click',()=>{
          schedState.openYears[year]=!schedState.openYears[year];
          yrBody.style.display=schedState.openYears[year]?'block':'none';
          arrow.textContent=schedState.openYears[year]?'▲':'▼';
        });
        add(yrSec,yrHdr,yrBody);
        add(schedP,yrSec);
      });
    }
  }

  rebuildSchedContent(loan);
  panels['sched']=schedP;

  // EARLY
  const earlyP=div(null,{style:{display:savedTab==='early'?'block':'none'}});
  add(earlyP,mk('p',null,'תוספת חודשית מעבר לתשלום הרגיל:',{style:{fontSize:'13px',color:'var(--text2)',marginBottom:'12px'}}));
  const earlyInp=inputField(null,{type:'number',placeholder:'למשל: 500'});
  const earlyRes=div('mt16');
  earlyInp.addEventListener('input',()=>{
    earlyRes.innerHTML='';
    const ex=parseFloat(earlyInp.value);
    if(!isNaN(ex)&&ex>0){
      const r=earlyCalc(loan,ex,S.cpi);
      if(r){
        const box=div(null,{style:{background:'rgba(16,185,129,.08)',border:'1px solid rgba(16,185,129,.25)',borderRadius:'16px',padding:'18px'}});
        add(box,mk('p',null,'✨ חיסכון בסגירה מוקדמת',{style:{margin:'0 0 12px',fontSize:'14px',fontWeight:'800',color:'#10b981'}}));
        const g=div('g2 mb12');
        add(g,statBox('חיסכון בריבית',ils(r.saved),'','var(--green)'),statBox('קיצור תקופה',r.savedM+' חודשים','','var(--green)'));
        add(box,g);
        const ned=div();ned.innerHTML='תאריך סיום חדש: <span style="color:#10b981;font-weight:700">'+fmtMY(r.newEnd)+'</span>';
        ned.style.cssText='font-size:12px;color:var(--text4)';
        add(box,ned);add(earlyRes,box);
      }
    }else{
      const ph=div('empty',{style:{padding:'24px 0'}});
      add(ph,mk('p',null,'🧮',{style:{fontSize:'32px',margin:'0 0 8px'}}),mk('p',null,'הכנס סכום תוספת לחישוב'));
      add(earlyRes,ph);
    }
  });
  earlyInp.dispatchEvent(new Event('input'));
  add(earlyP,earlyInp,earlyRes);
  panels['early']=earlyP;

  // PAYMENTS
  const paysP=div(null,{style:{display:savedTab==='pays'?'block':'none'}});
  function renderPays(){
    paysP.innerHTML='';
    const pmts=loan.payments||[];
    if(!pmts.length){
      const ph=div('empty',{style:{padding:'30px 0'}});
      add(ph,mk('p',null,'💸',{style:{fontSize:'28px',margin:'0 0 8px'}}),mk('p',null,'אין תשלומים נוספים עדיין'));
      add(paysP,ph);
    }else{
      [...pmts].reverse().forEach(p=>{
        const r=div('row-between',{style:{background:'rgba(255,255,255,.03)',borderRadius:'12px',padding:'12px 14px',marginBottom:'8px'}});
        add(r,mk('span','boldest',ils2(p.amount),{style:{color:'var(--green)',fontSize:'16px'}}),
          mk('span','small dim',new Date(p.date).toLocaleDateString('he-IL')));
        add(paysP,r);
      });
    }
  }
  renderPays();
  panels['pays']=paysP;

  add(panelWrap,...Object.values(panels));
  add(card,panelWrap);

  // FIX: refreshCard — בנה מחדש רק את הכרטיס הזה ב-DOM
  card._rebuildSched=(freshLoan)=>rebuildSchedContent(freshLoan);

  return card;
}

// ═══════════════════════════════════════════════════════════
//  REFRESH CARD — לא render() מלא, רק כרטיס ספציפי
// ═══════════════════════════════════════════════════════════
function refreshCard(loanId){
  const existingCard=document.querySelector(`[data-loan-id="${loanId}"]`);
  if(!existingCard)return render(); // fallback
  const freshLoan=S.loans.find(l=>l.id==loanId);
  if(!freshLoan)return render();
  const ci=S.loans.findIndex(l=>l.id==loanId);
  const newCard=buildCard(freshLoan,ci);
  existingCard.replaceWith(newCard);
  renderSummary();
}

// ═══════════════════════════════════════════════════════════
//  RENDER SUMMARY ONLY
// ═══════════════════════════════════════════════════════════
function renderSummary(){
  const sumEl=document.getElementById('summary-grid');
  if(!sumEl)return;
  const totals=S.loans.reduce((a,l)=>{const s=stats(l,S.cpi);return{b:a.b+s.balance,p:a.p+s.curPmt,i:a.i+s.totalInt};},{b:0,p:0,i:0});
  sumEl.innerHTML='';
  [{l:'סה"כ חוב',v:ils(totals.b),c:'var(--red)',bg:'rgba(248,113,113,.08)',br:'rgba(248,113,113,.2)'},
   {l:'תשלום חודשי',v:ils(totals.p),c:'var(--blue)',bg:'rgba(99,102,241,.08)',br:'rgba(99,102,241,.2)'},
   {l:'סה"כ ריבית',v:ils(totals.i),c:'var(--orange)',bg:'rgba(251,146,60,.08)',br:'rgba(251,146,60,.2)'}
  ].forEach(s=>{
    const b=div('sum-box',{style:{background:s.bg,border:'1px solid '+s.br}});
    add(b,mk('p',null,s.l,{style:{margin:'0',fontSize:'10px',color:s.c,fontWeight:'700',letterSpacing:'1px'}}),
      mk('p',null,s.v,{style:{margin:'4px 0 0',fontSize:'15px',fontWeight:'900',color:s.c}}));
    add(sumEl,b);
  });
}

// ═══════════════════════════════════════════════════════════
//  COMPARE VIEW
// ═══════════════════════════════════════════════════════════
function buildCompare(){
  const wrap=div();
  if(S.loans.length<2){
    const e=div('empty');add(e,mk('p',null,'⚖️',{style:{fontSize:'40px',margin:'0 0 12px'}}),mk('p','bolder','הוסף לפחות 2 הלוואות להשוואה'));
    return add(wrap,e);
  }
  add(wrap,mk('p',null,'השוואת כל ההלוואות',{style:{fontSize:'13px',color:'var(--text4)',marginBottom:'16px'}}));
  const rows=S.loans.map((l,i)=>({s:stats(l,S.cpi),loan:l,color:COLORS[i%COLORS.length]}));
  const maxB=Math.max(...rows.map(r=>r.s.balance),1);
  const maxI=Math.max(...rows.map(r=>r.s.totalInt),1);
  rows.forEach(r=>{
    const c=div('cmp-card',{style:{border:'1px solid '+r.color+'33'}});
    const top=div('row-between mb12');
    const left=div();
    add(left,tag(r.color,r.loan.loanType||'שפיצר'),mk('p',null,r.loan.name,{style:{margin:'6px 0 0',fontSize:'16px',fontWeight:'800'}}));
    add(top,left,mk('p',null,ils(r.s.balance),{style:{margin:'0',fontSize:'22px',fontWeight:'900',color:r.color}}));
    add(c,top);
    [{label:'יתרה נוכחית',v:r.s.balance,max:maxB,color:r.color},{label:'סה"כ ריבית',v:r.s.totalInt,max:maxI,color:'var(--orange)'}].forEach(bar=>{
      const bw=div('mb8');
      const bl=div('row-between smaller dim mb8');add(bl,mk('span',null,bar.label),mk('span',null,ils(bar.v)));
      const track=div(null,{style:{height:'6px',background:'rgba(255,255,255,.05)',borderRadius:'10px',overflow:'hidden'}});
      add(track,div(null,{style:{height:'100%',width:Math.round(bar.v/bar.max*100)+'%',background:bar.color,borderRadius:'10px',transition:'width .7s'}}));
      add(bw,bl,track);add(c,bw);
    });
    const meta=div('row mt12',{style:{gap:'16px',fontSize:'12px',flexWrap:'wrap'}});
    const metaItem=(label,val,color)=>{const s=mk('span',null,'');add(s,mk('span',null,label,{style:{color:'var(--text4)'}}),mk('span','bold',val,{style:{color}}));return s;};
    add(meta,metaItem('ריבית: ',r.loan.annualRate+'%','var(--text)'),metaItem('תשלום: ',ils(r.s.curPmt),r.color),metaItem('נותר: ',r.s.monthsLeft+' חודשים','var(--yellow)'));
    add(c,meta);add(wrap,c);
  });
  return wrap;
}

// ═══════════════════════════════════════════════════════════
//  MAIN RENDER
// ═══════════════════════════════════════════════════════════
function render(){
  const app=document.getElementById('app');
  app.innerHTML='';

  const totals=S.loans.reduce((a,l)=>{const s=stats(l,S.cpi);return{b:a.b+s.balance,p:a.p+s.curPmt,i:a.i+s.totalInt};},{b:0,p:0,i:0});
  const hasCpi=S.loans.some(l=>l.loanType==='צמוד מדד');

  // ── Header ──
  const hdr=div('hdr');const hw=div('wrap');

  const topBar=div('row-between mb16');
  const titleBlock=div();
  add(titleBlock,
    mk('p',null,'מעקב הלוואות',{style:{margin:'0',fontSize:'10px',color:'var(--accent)',fontWeight:'700',letterSpacing:'3px',textTransform:'uppercase'}}),
    mk('h1',null,'היד על הדופק 💳',{style:{margin:'2px 0 0',fontSize:'23px',fontWeight:'900'}}));
  add(topBar,titleBlock);

  const acts=div('row',{style:{gap:'8px'}});
  if(hasCpi)add(acts,btn(null,'📊',()=>openCpiSheet(),{style:{background:'rgba(16,185,129,.12)',border:'1px solid rgba(16,185,129,.25)',color:'#10b981',borderRadius:'12px',padding:'8px 12px',cursor:'pointer',fontSize:'15px',fontWeight:'700'}}));
  add(acts,
    btn(null,'📥',exportCSV,{style:{background:'rgba(99,102,241,.12)',border:'1px solid rgba(99,102,241,.25)',color:'var(--blue)',borderRadius:'12px',padding:'8px 12px',cursor:'pointer',fontSize:'15px'}}),
    btn(null,'+ הלוואה',()=>openLoanSheet(null),{style:{background:'linear-gradient(135deg,var(--accent),var(--accent2))',border:'none',color:'#fff',borderRadius:'12px',padding:'9px 14px',cursor:'pointer',fontSize:'13px',fontWeight:'800'}}));
  add(topBar,acts);add(hw,topBar);

  // Summary — FIX: id לצורך renderSummary()
  const sg=div('sum-grid',{id:'summary-grid'});
  [{l:'סה"כ חוב',v:ils(totals.b),c:'var(--red)',bg:'rgba(248,113,113,.08)',br:'rgba(248,113,113,.2)'},
   {l:'תשלום חודשי',v:ils(totals.p),c:'var(--blue)',bg:'rgba(99,102,241,.08)',br:'rgba(99,102,241,.2)'},
   {l:'סה"כ ריבית',v:ils(totals.i),c:'var(--orange)',bg:'rgba(251,146,60,.08)',br:'rgba(251,146,60,.2)'}
  ].forEach(s=>{
    const b=div('sum-box',{style:{background:s.bg,border:'1px solid '+s.br}});
    add(b,mk('p',null,s.l,{style:{margin:'0',fontSize:'10px',color:s.c,fontWeight:'700',letterSpacing:'1px'}}),
      mk('p',null,s.v,{style:{margin:'4px 0 0',fontSize:'15px',fontWeight:'900',color:s.c}}));
    add(sg,b);
  });
  add(hw,sg);

  // View tabs
  const vTabs=div('tabs');
  [['loans','הלוואות ('+S.loans.length+')'],['compare','השוואה']].forEach(([id,label])=>{
    const t=mk('button','tab',label);
    if(S.view===id)t.classList.add('on');
    t.addEventListener('click',()=>{S.view=id;render();});
    add(vTabs,t);
  });
  add(hw,vTabs);add(hdr,hw);add(app,hdr);

  // ── Content ──
  const content=div('content');
  if(S.view==='loans'){
    if(!S.loans.length){
      const e=div('empty',{style:{padding:'80px 0'}});
      add(e,mk('p',null,'🏦',{style:{fontSize:'52px',margin:'0 0 16px'}}),
        mk('p','bolder','אין הלוואות עדיין',{style:{fontSize:'18px',color:'var(--text4)',marginBottom:'8px'}}),
        mk('p','dim mb20','לחץ כדי להוסיף הלוואה ראשונה'),
        btn('btn-primary','+ הוסף הלוואה ראשונה',()=>openLoanSheet(null),{style:{maxWidth:'260px',margin:'0 auto'}}));
      add(content,e);
    }else{
      S.loans.forEach((loan,i)=>add(content,buildCard(loan,i)));
    }
  }else{
    add(content,buildCompare());
  }
  add(app,content);

  // Install banner (PWA)
  const bar=div('install-bar',{id:'install-bar'});
  const barText=div();
  add(barText,mk('p',null,'📲 הוסף לדף הבית',{style:{margin:'0',fontSize:'13px',fontWeight:'700',color:'var(--blue)'}}),
    mk('p',null,'התקן כאפליקציה על הטלפון',{style:{margin:'0',fontSize:'11px',color:'var(--text4)'}}));
  add(bar,barText,btn(null,'התקן',()=>{if(window._deferredInstall){window._deferredInstall.prompt();}},
    {style:{background:'linear-gradient(135deg,var(--accent),var(--accent2))',border:'none',color:'#fff',borderRadius:'10px',padding:'8px 16px',cursor:'pointer',fontWeight:'700',fontSize:'13px',whiteSpace:'nowrap'}}));
  add(app,bar);
}

// ═══════════════════════════════════════════════════════════
//  PWA & INIT
// ═══════════════════════════════════════════════════════════
if('serviceWorker' in navigator){
  navigator.serviceWorker.register('./sw.js').catch(()=>{});
}

window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault();window._deferredInstall=e;
  const b=document.getElementById('install-bar');
  if(b)b.style.display='flex';
});
window.addEventListener('appinstalled',()=>{
  const b=document.getElementById('install-bar');if(b)b.style.display='none';
});

render();
</script>
</body>
</html>
