function exportCSV(){
  const rows=[['שם','סוג','קרן','ריבית','חודשים','יתרה','ריבית ששולמה','סה"כ ריבית','תשלום חודשי','חודשים נותרים','תאריך סיום','חודשים מפוגרים','קרן מפוגרת','ריבית פיגורים','סה"כ פיגורים']];
  S.loans.forEach(l=>{
    const s=stats(l,S.cpi);
    rows.push([l.name,l.loanType||'שפיצר',l.principal,l.annualRate+'%',l.termMonths,
      s.balance.toFixed(2),s.paidInt.toFixed(2),s.totalInt.toFixed(2),
      s.curPmt.toFixed(2),s.monthsLeft,s.endDate?s.endDate.toLocaleDateString('he-IL'):'',
      s.arrears.missedCount,s.arrears.principal.toFixed(2),s.arrears.penalty.toFixed(2),s.arrears.total.toFixed(2)]);
  });
  S.loans.forEach(l=>{
    rows.push([],[`לוח סילוקין - ${l.name}`],['חודש','תאריך','תשלום','ריבית','קרן','יתרה','סטטוס']);
    const missed=new Set((l.missedMonths||[]).map(m=>m.ymStr));
    const now=new Date();
    buildSchedule(l,S.cpi).forEach(r=>{
      const status=r.date>now?'עתידי':missed.has(r.ymStr)?'מפוגר':'שולם';
      rows.push([r.month,r.label,r.payment.toFixed(2),r.interest.toFixed(2),r.principal.toFixed(2),r.balance.toFixed(2),status]);
    });
  });
  const csv='\uFEFF'+rows.map(r=>r.map(v=>'"'+v+'"').join(',')).join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));
  a.download='הלוואות.csv';a.click();
}

