      }else{prevBox.style.display='none';}
    }

    function refreshType(){
      rateRow.style.display=isPrimeNow()?'none':'block';
      spreadRow.style.display=isPrimeNow()?'block':'none';
      cpiNote.style.display=loanType==='צמוד מדד'?'block':'none';
      updatePreview();
    }

    typeSelect.addEventListener('change',()=>{loanType=typeSelect.value;refreshType();});
    [nInp,pInp,rInp,sInp,tInp,dtInp].forEach(i=>i.addEventListener('input',updatePreview));

    add(rateRow,lbl('ריבית שנתית (%)'),rInp);
    add(spreadRow,lbl('מרווח מעל פריים (%)'),sInp,
      mk('p',null,'ריבית הפריים תוזן דרך כפתור 📈 בכרטיס',{style:{fontSize:'11px',color:'var(--text4)',marginTop:'4px'}}));

    const twoCol=div('g2',{style:{marginTop:'14px'}});
    const c1=div();add(c1,lbl('תקופה (חודשים)'),tInp);
    const c2=div();add(c2,lbl('חודש תחילה'),dtInp);
    add(twoCol,c1,c2);

    add(sheet,
      mk('h2',null,editLoan?'עריכת הלוואה':'הלוואה חדשה',{style:{fontWeight:'800',fontSize:'20px',marginBottom:'18px'}}),
      lbl('שם'),nInp,lbl('סוג הלוואה'),typeSelect,lbl('קרן (₪)'),pInp,
      rateRow,spreadRow,twoCol,cpiNote,prevBox,
      lbl('ריבית פיגורים שנתית % (אופציונלי)'),penInp,
      lbl('ימי חסד לפני תחילת חיוב פיגורים'),graceInp,
      mk('p',null,'ברירת מחדל: 14 יום — כמו ברוב הבנקים',{style:{fontSize:'11px',color:'var(--text4)',marginTop:'4px'}}));

    refreshType();

    const btns=div('row mt20',{style:{gap:'10px'}});
    const saveB=btn('btn-primary',editLoan?'שמור שינויים':'הוסף הלוואה',()=>{
      const name=nInp.value.trim();
      const principal=pInp.value,termMonths=tInp.value,startDate=dtInp.value;
      const annualRate=isPrimeNow()?sInp.value:rInp.value;
      if(!name||!parseFloat(principal)||!parseInt(termMonths)||!parseDate(startDate))return;
      const loan={
        id:editLoan?editLoan.id:Date.now(),name,loanType,principal,annualRate,
        spread:isPrimeNow()?sInp.value:'',termMonths,startDate,
