<style>
:root{
  --bg:#070712;--bg2:#0d0d1f;--bg3:#161630;
  --border:rgba(255,255,255,.07);
  --text:#f1f5f9;--text2:#94a3b8;--text3:#475569;--text4:#64748b;
  --accent:#6366f1;--accent2:#8b5cf6;
  --red:#f87171;--green:#4ade80;--yellow:#fbbf24;--orange:#fb923c;--blue:#a5b4fc;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,0px);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{font-size:16px;-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--text);font-family:'Heebo',sans-serif;direction:rtl;min-height:100vh;min-height:-webkit-fill-available;overscroll-behavior:none}
input,select,button,textarea{font-family:'Heebo',sans-serif;font-size:16px}
input::-webkit-inner-spin-button{opacity:.4}
input[type=month]{color-scheme:dark}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:#334155;border-radius:4px}
select option{background:#1e1e3a;color:var(--text)}
button{-webkit-appearance:none;appearance:none}

/* ── Layout ── */
#app{min-height:100vh;min-height:-webkit-fill-available}
.hdr{background:linear-gradient(180deg,#0e0e22 0%,var(--bg) 100%);
  border-bottom:1px solid var(--border);
  padding:calc(var(--safe-top) + 18px) 16px 0;
  position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)}
.wrap{max-width:540px;margin:0 auto}
.content{max-width:540px;margin:0 auto;padding:16px 16px calc(var(--safe-bot) + 80px)}

/* ── Inputs ── */
.inp{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);
  border-radius:12px;padding:13px 15px;color:var(--text);font-size:16px;
  outline:none;width:100%;direction:rtl;transition:border-color .15s}
.inp:focus{border-color:var(--accent)}
.field-lbl{font-size:12px;color:var(--accent);font-weight:700;display:block;margin:14px 0 6px}
.field-lbl:first-child{margin-top:0}

/* ── Buttons ── */
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));
  border:none;color:#fff;border-radius:14px;padding:14px 0;cursor:pointer;
  font-weight:800;font-size:16px;width:100%;transition:opacity .15s}
.btn-primary:active{opacity:.8}
.btn-ghost{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);
  color:var(--text4);border-radius:14px;padding:14px 0;cursor:pointer;
  font-weight:700;font-size:15px;width:100%}
.btn-ghost:active{background:rgba(255,255,255,.1)}
.btn-icon{background:none;border:none;cursor:pointer;border-radius:10px;
  width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:15px;transition:background .15s}
.btn-icon:active{background:rgba(255,255,255,.12)}

/* ── Cards ── */
.card{background:linear-gradient(145deg,var(--bg2),var(--bg3));
  border-radius:22px;overflow:hidden;margin-bottom:14px;
  box-shadow:0 4px 24px rgba(0,0,0,.35)}
.stat-box{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);
  border-radius:14px;padding:14px 12px}

/* ── Tags ── */
.tag{font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.5px}

/* ── Tabs ── */
.tabs{display:flex}
.tab{flex:1;background:none;border:none;border-bottom:2px solid transparent;
  cursor:pointer;padding:11px 0;font-size:11px;font-weight:700;color:var(--text3);transition:color .15s}
.tab.on{color:var(--tab-c,var(--accent));border-bottom-color:var(--tab-c,var(--accent))}

/* ── Progress ── */
.prog-track{height:5px;background:rgba(255,255,255,.06);border-radius:10px;overflow:hidden}
.prog-fill{height:100%;border-radius:10px;transition:width .7s cubic-bezier(.4,0,.2,1)}

/* ── Modal ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:200;
  display:flex;align-items:flex-end;justify-content:center;
  animation:fadeIn .2s ease}
.sheet{background:linear-gradient(180deg,#12122a,#0d0d20);
  border-radius:24px 24px 0 0;padding:20px 20px calc(var(--safe-bot) + 20px);
  width:100%;max-width:540px;max-height:92vh;overflow-y:auto;
  animation:slideUp .25s cubic-bezier(.4,0,.2,1)}
.sheet-handle{width:40px;height:4px;background:rgba(255,255,255,.15);
  border-radius:2px;margin:0 auto 20px}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{transform:translateY(40px);opacity:0}to{transform:translateY(0);opacity:1}}

/* ── Summary ── */
.sum-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.sum-box{border-radius:14px;padding:13px 10px;text-align:center}

/* ── Schedule ── */
.sched-row{display:grid;grid-template-columns:1fr 72px 72px 82px;gap:4px;
  padding:8px 6px;border-radius:10px;margin-bottom:2px;font-size:12px;transition:background .1s}

/* ── Empty ── */
.empty{text-align:center;padding:64px 0;color:var(--text4)}

/* ── Compare bars ── */
.cmp-card{background:rgba(255,255,255,.03);border-radius:18px;padding:18px;margin-bottom:12px}

/* ── Install banner ── */
.install-bar{background:linear-gradient(135deg,rgba(99,102,241,.15),rgba(139,92,246,.15));
  border-top:1px solid rgba(99,102,241,.2);padding:12px 16px;
  display:none;align-items:center;justify-content:space-between;gap:12px}

/* ── Animations ── */
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.loading{animation:pulse 1.5s infinite}

.arrears-box{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);border-radius:16px;padding:16px;margin-bottom:14px}

/* ── Toggle switch ── */
.toggle-wrap{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:12px;margin-bottom:3px;transition:background .15s;cursor:pointer;user-select:none;-webkit-user-select:none}
.toggle-wrap:active{background:rgba(255,255,255,.04)}
.toggle-wrap.is-missed{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2)}
.toggle-wrap.is-future{opacity:.4;cursor:default}
.toggle-wrap.is-cur{background:var(--cur-color,rgba(99,102,241,.1));border:1px solid var(--cur-border,rgba(99,102,241,.3))}
.sw{width:42px;height:22px;border-radius:11px;background:#334155;position:relative;transition:background .25s;flex-shrink:0}
.sw.on{background:#4ade80}
.sw.missed{background:#f87171}
.sw::after{content:'';position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:2px;right:2px;transition:right .25s}
.sw.on::after,.sw.missed::after{right:22px}
/* ── Year accordion ── */
.yr-hdr{display:flex;justify-content:space-between;align-items:center;padding:11px 14px;background:rgba(255,255,255,.04);border-radius:12px;margin-bottom:4px;cursor:pointer;font-weight:800;font-size:13px;transition:background .15s}
.yr-hdr:active{background:rgba(255,255,255,.08)}
.yr-hdr .yr-badge{font-size:11px;font-weight:700;padding:2px 8px;border-radius:8px}
/* ── Sched view toggle ── */
.sched-view-btns{display:flex;gap:6px;margin-bottom:12px}
.sched-view-btn{flex:1;padding:7px 0;border:1px solid rgba(255,255,255,.1);background:transparent;border-radius:10px;font-size:12px;font-weight:700;color:var(--text4);cursor:pointer;transition:all .15s}
.sched-view-btn.on{background:rgba(99,102,241,.2);border-color:var(--accent);color:var(--blue)}

/* ── Utilities ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.g3{display:grid;grid-template-columns:1fr 1fr auto;gap:8px;align-items:end}
.row{display:flex;gap:8px;align-items:center}
.row-between{display:flex;justify-content:space-between;align-items:center}
.mt8{margin-top:8px} .mt12{margin-top:12px} .mt16{margin-top:16px} .mt20{margin-top:20px}
.mb8{margin-bottom:8px} .mb12{margin-bottom:12px} .mb16{margin-bottom:16px}
.bold{font-weight:700} .bolder{font-weight:800} .boldest{font-weight:900}
.small{font-size:12px} .smaller{font-size:11px} .xs{font-size:10px}
.dim{color:var(--text4)} .dim2{color:var(--text3)}
</style>
