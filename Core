  const savedTab=S.activeTab[loan.id]||'info';
  tabDefs.forEach(([id,label])=>{
    const t=mk('button','tab',label);t.style.setProperty('--tab-c',color);
    if(id===savedTab)t.classList.add('on');
    t.addEventListener('click',()=>{
      S.activeTab[loan.id]=id;
